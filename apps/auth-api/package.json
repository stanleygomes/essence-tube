{
  "name": "auth-api",
  "type": "module",
  "version": "1.6.0",
  "scripts": {
    "start": "npx vercel dev",
    "start:fastify": "SERVER_PORT=5000 node --loader ts-node/esm src/infra/web/fastify/server.ts",
    "build": "echo 'No build step required'",
    "dev": "NODE_TLS_REJECT_UNAUTHORIZED=0 npx vercel dev --listen 5000 --debug",
    "dev:fastify": "npm run start:fastify",
    "deploy": "npx vercel --prod",
    "lint": "eslint --max-warnings 0",
    "lint:fix": "eslint --fix",
    "check-types": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "containers:up": "docker-compose -f docker-compose.dev.yml up -d",
    "containers:down": "docker-compose -f docker-compose.dev.yml down"
  },
  "_moduleAliases": {
    "@": "src"
  },
  "dependencies": {
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@logos/utils": "^0.0.0",
    "axios": "^1.10.0",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.45.1",
    "express": "^5.1.0",
    "fastify": "^5.4.0",
    "resend": "^6.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@logos/eslint-config": "*",
    "@logos/typescript-config": "*",
    "@types/axios": "^0.9.36",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mustache": "^4.2.6",
    "@types/node": "^24.0.3",
    "@types/uuid": "^10.0.0",
    "@vercel/node": "^5.6.6",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.1",
    "globals": "^16.2.0",
    "prettier": "^3.5.3",
    "ts-node": "^10.9.1",
    "typescript": "5.9.2"
  }
}
