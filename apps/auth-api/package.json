{
  "name": "auth-api",
  "type": "module",
  "version": "1.6.0",
  "scripts": {
    "start": "npx vercel dev",
    "start:fastify": "SERVER_PORT=5000 node --loader ts-node/esm src/server.ts",
    "build": "echo 'No build step required'",
    "dev": "NODE_TLS_REJECT_UNAUTHORIZED=0 npx vercel dev --listen 5000 --debug",
    "dev:fastify": "npm run start:fastify",
    "deploy": "npx vercel --prod",
    "lint": "eslint --max-warnings 0",
    "lint:fix": "eslint --fix",
    "check-types": "tsc --noEmit",
    "containers:up": "docker-compose -f docker-compose.dev.yml up -d",
    "containers:down": "docker-compose -f docker-compose.dev.yml down"
  },
  "_moduleAliases": {
    "@": "src"
  },
  "dependencies": {
    "@fastify/formbody": "^8.0.2",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "axios": "^1.10.0",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^16.5.0",
    "fastify": "^5.4.0",
    "jsonwebtoken": "^9.0.2",
    "jwt-decode": "^4.0.0",
    "nodemailer": "^8.0.1",
    "pino": "^9.7.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.0.3",
    "@types/nodemailer": "^6.4.17",
    "@types/uuid": "^10.0.0",
    "@vercel/node": "^5.6.6",
    "eslint": "^9.39.1",
    "globals": "^16.2.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.5.3",
    "ts-node": "^10.9.1",
    "typescript": "5.9.2"
  }
}
