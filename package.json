{
  "name": "essence-tube-monorepo",
  "version": "1.8.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "ui": "turbo run dev --filter=ui",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "check": "pnpm run format:check && pnpm run lint && pnpm run check-types",
    "fix": "pnpm run format && pnpm run lint:fix && pnpm run check-types",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "minimatch": "^10.2.5",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "turbo": "^2.8.10",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.31.0"
}